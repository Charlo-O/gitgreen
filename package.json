{
  "name": "github-contrib-poster",
  "version": "0.1.0",
  "description": "Generate a long poster comparing GitHub contributions year by year.",
  "type": "module",
  "bin": {
    "github-contrib-poster": "./src/cli.js"
  },
  "scripts": {
